{
  "name": "appstage",
  "version": "0.2.2",
  "description": "",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "bin": {
    "appstage": "./dist/bin.js"
  },
  "scripts": {
    "compile-bin": "esbuild src/scripts/bin.ts --bundle --outfile=dist/bin.js --platform=node --external:esbuild --format=esm",
    "preversion": "npx npm-run-all shape compile-bin",
    "shape": "npx codeshape",
    "typecheck": "npx codeshape typecheck"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/axtk/appstage.git"
  },
  "author": "axtk",
  "license": "MIT",
  "peerDependencies": {
    "express": ">=5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0"
  },
  "dependencies": {
    "dateshape": "^1.1.2",
    "esbuild": "^0.27.3"
  }
}
